POSTGRES_USER=smartlekka
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=smartlekka

DATABASE_URL=postgres://smartlekka:change_this_strong_password@db:5432/smartlekka

JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_32_chars
SESSION_SECRET=change_this_to_another_long_random_secret

# Host port the app is reachable on. Default 8081 so it doesn't clash with
# other apps already using port 80/443 on a shared droplet.
APP_PORT=8081
